# ==========================================
# LifeOS Backend Configuration
# ==========================================

# 1. Django Settings
# ==========================================
# The secret key for cryptographic signing. Generate a new one for production!
SECRET_KEY=your-super-secret-key-do-not-share

# Debug mode. MUST be False in production to prevent leaking stack traces.
DEBUG=False

# Comma-separated list of allowed host/domain names.
ALLOWED_HOSTS=api.yourdomain.com,www.yourdomain.com

# Comma-separated list of allowed origins for cross-origin requests.
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 2. Database Configuration
# ==========================================
# PostgreSQL connection string using dj-database-url format
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://postgres:password@localhost:5432/lifeos

# 3. Security Configuration
# ==========================================
# Force HTTPS redirects
SECURE_SSL_REDIRECT=True

# 4. Environment Setting
# ==========================================
# Define which settings module to use (default in prod is config.settings.production)
DJANGO_SETTINGS_MODULE=config.settings.production

# 5. Logging Config
# ==========================================
LOG_LEVEL=INFO
