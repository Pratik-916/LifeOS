{
  "name": "lifeos-monorepo",
  "version": "1.0.0",
  "description": "LifeOS Unified Test Runner",
  "private": true,
  "scripts": {
    "test:backend": "cd backend && .\\.venv\\Scripts\\python -m pytest --cov=. --cov-report=html --cov-report=xml",
    "test:web": "cd frontend && npm run test:coverage",
    "test:mobile": "cd mobile && npm run test:coverage",
    "test:e2e": "cd mobile && maestro test .maestro/",
    "test:all": "npm run test:backend && npm run test:web && npm run test:mobile"
  }
}
